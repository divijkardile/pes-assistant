# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------

APP_NAME=PES Assistant
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1

# ------------------------------------------------------------------
# Retry Policy
# ------------------------------------------------------------------

RETRY_MAX_ATTEMPTS=2
RETRY_INITIAL_DELAY=0.5
RETRY_BACKOFF_MULTIPLIER=2.0

# ------------------------------------------------------------------
# LLM Provider
# ------------------------------------------------------------------

LLM_PROVIDER=ollama

# ------------------------------------------------------------------
# Ollama
# ------------------------------------------------------------------

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------------
# AWS Bedrock
# ------------------------------------------------------------------

AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY= 
AWS_SESSION_TOKEN=

# ------------------------------------------------------------------
# Open AI
# ------------------------------------------------------------------

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_Embedding_MODEL= "text-embedding-3-small"

# ------------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------------

EMBEDDING_DIMENSION=768

# ------------------------------------------------------------------
# Qdrant
# ------------------------------------------------------------------

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=test

# ------------------------------------------------------------------
# Semantic Cache
# ------------------------------------------------------------------

SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_COLLECTION_NAME=semantic_cache
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_MINUTES=30

# ------------------------------------------------------------------
# Documents
# ------------------------------------------------------------------

DOCUMENT_PATH=./documents

# ------------------------------------------------------------------
# Session
# ------------------------------------------------------------------

SESSION_TIMEOUT_MINUTES=30

# ------------------------------------------------------------------
# Agent Robustness (Timeout & Loop Prevention)
# ------------------------------------------------------------------

AGENT_TIMEOUT_SECONDS=30
AGENT_MAX_ITERATIONS=5
TOOL_TIMEOUT_SECONDS=15
ENABLE_LOOP_DETECTION=true
LOOP_DETECTION_THRESHOLD=4

# ------------------------------------------------------------------
# OAuth Configuration
# ------------------------------------------------------------------

OAUTH_ENABLED=false
OAUTH_TOKEN_URL=
OAUTH_SCOPE=

# ------------------------------------------------------------------
# External API Endpoints
# ------------------------------------------------------------------

EXTERNAL_API_PES_BASE_URL=
EXTERNAL_API_DOCUMENTS_BASE_URL=

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------

LOG_LEVEL=INFO