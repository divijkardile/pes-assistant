# ==========================================
# Application
# ==========================================

APP_NAME=PES Assistant
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ==========================================
# API
# ==========================================

API_PREFIX=/api/v1

# ==========================================
# Ollama
# ==========================================

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ==========================================
# Session
# ==========================================

SESSION_TIMEOUT_MINUTES=30

# ==========================================
# Logging
# ==========================================

LOG_LEVEL=INFO